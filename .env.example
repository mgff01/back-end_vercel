# Variáveis de Ambiente para Integração Gov.BR

# Django
SECRET_KEY=sua-chave-secreta-aqui
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# OAuth Gov.BR (obter em: https://www.gov.br/governodigital/pt-br/estrategias-e-governanca-digital/transformacao-digital/servico-de-integracao-aos-produtos-de-identidade-digital-gov.br)
GOVBR_CLIENT_ID=seu-client-id
GOVBR_CLIENT_SECRET=seu-client-secret
GOVBR_REDIRECT_URI=http://127.0.0.1:8000/api/govbr-callback/

# Endpoints Gov.BR
GOVBR_OAUTH_ENDPOINT=https://acesso.gov.br/authorize
GOVBR_API_ENDPOINT=https://api-assinatura.servicos.gov.br

# Banco de Dados
DATABASE_URL=sqlite:///db.sqlite3

# CORS
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
